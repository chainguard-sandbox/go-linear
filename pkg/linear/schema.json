{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "go-linear API Schema",
  "description": "Type definitions for the go-linear Linear API client",
  "definitions": {
    "IssueCreateInput": {
      "type": "object",
      "description": "Input for creating a new Linear issue",
      "required": ["teamID"],
      "properties": {
        "teamID": {
          "type": "string",
          "description": "Team UUID (required). Get from: client.Teams(ctx, nil, nil)[0].ID",
          "example": "87f863b0-b00c-4059-827c-1d163b557bdd"
        },
        "title": {
          "type": ["string", "null"],
          "description": "Issue title (optional pointer)"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Issue description in markdown format (optional pointer)"
        },
        "priority": {
          "type": ["integer", "null"],
          "description": "Priority level (optional pointer)",
          "enum": [0, 1, 2, 3, 4],
          "x-enum-descriptions": {
            "0": "None",
            "1": "Urgent (red)",
            "2": "High (orange)",
            "3": "Normal (yellow)",
            "4": "Low (gray)"
          }
        },
        "assigneeID": {
          "type": ["string", "null"],
          "description": "User UUID to assign (optional). Get from: client.Users(ctx, nil, nil)[0].ID or client.Viewer(ctx).ID"
        },
        "stateID": {
          "type": ["string", "null"],
          "description": "Workflow state UUID (optional). Get from: client.WorkflowStates(ctx, nil, nil)[0].ID. Must belong to the same team."
        },
        "labelIds": {
          "type": ["array", "null"],
          "description": "Array of label UUIDs to apply (optional). Get from: client.IssueLabels(ctx, nil, nil)[0].ID",
          "items": {
            "type": "string"
          }
        },
        "parentID": {
          "type": ["string", "null"],
          "description": "Parent issue UUID for creating sub-issues (optional). Must be in same team."
        },
        "dueDate": {
          "type": ["string", "null"],
          "description": "Due date in YYYY-MM-DD format (optional)",
          "format": "date",
          "example": "2024-12-25"
        },
        "projectID": {
          "type": ["string", "null"],
          "description": "Project UUID to associate with (optional). Get from: client.Projects(ctx, nil, nil)[0].ID"
        },
        "cycleID": {
          "type": ["string", "null"],
          "description": "Cycle/sprint UUID (optional). Get from: client.Cycles(ctx, nil, nil)[0].ID"
        }
      }
    },
    "IssueUpdateInput": {
      "type": "object",
      "description": "Input for updating an existing issue. All fields optional (nil = unchanged)",
      "properties": {
        "title": {
          "type": ["string", "null"],
          "description": "New issue title (nil = unchanged)"
        },
        "description": {
          "type": ["string", "null"],
          "description": "New description (nil = unchanged)"
        },
        "priority": {
          "type": ["integer", "null"],
          "enum": [0, 1, 2, 3, 4],
          "description": "New priority level (nil = unchanged)"
        },
        "assigneeID": {
          "type": ["string", "null"],
          "description": "New assignee UUID (nil = unchanged, empty string \"\" = unassign)"
        },
        "stateID": {
          "type": ["string", "null"],
          "description": "New workflow state UUID (nil = unchanged)"
        },
        "labelIds": {
          "type": ["array", "null"],
          "description": "Replace all labels with this array (nil = unchanged)",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Issue": {
      "type": "object",
      "description": "A Linear issue (returned by Issue, Issues, IssueCreate methods)",
      "properties": {
        "id": {
          "type": "string",
          "description": "Issue UUID (always present)"
        },
        "number": {
          "type": "number",
          "description": "Issue number in team (always present, e.g., 57 for HEX-57)"
        },
        "title": {
          "type": "string",
          "description": "Issue title (always present)"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Issue description in markdown (nullable)"
        },
        "url": {
          "type": "string",
          "description": "Web URL for the issue (always present)",
          "format": "uri"
        },
        "priority": {
          "type": ["integer", "null"],
          "enum": [0, 1, 2, 3, 4],
          "description": "Priority level (nullable)"
        },
        "state": {
          "$ref": "#/definitions/WorkflowState",
          "description": "Current workflow state (always present)"
        },
        "team": {
          "$ref": "#/definitions/Team",
          "description": "Team the issue belongs to (always present)"
        },
        "assignee": {
          "type": ["object", "null"],
          "description": "Assigned user (nullable, null = unassigned)",
          "properties": {
            "id": {"type": "string"},
            "name": {"type": "string"},
            "email": {"type": "string"}
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp (always present)"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp (always present)"
        }
      }
    },
    "IssueConnection": {
      "type": "object",
      "description": "Paginated list of issues (returned by Issues method)",
      "properties": {
        "nodes": {
          "type": "array",
          "description": "Array of issues (may be empty)",
          "items": {
            "$ref": "#/definitions/Issue"
          }
        },
        "pageInfo": {
          "$ref": "#/definitions/PageInfo",
          "description": "Pagination information"
        }
      }
    },
    "PageInfo": {
      "type": "object",
      "description": "Pagination information for cursor-based pagination",
      "properties": {
        "hasNextPage": {
          "type": "boolean",
          "description": "True if more results are available"
        },
        "endCursor": {
          "type": ["string", "null"],
          "description": "Cursor for next page (pass to 'after' parameter)"
        }
      }
    },
    "Team": {
      "type": "object",
      "description": "A Linear team",
      "properties": {
        "id": {
          "type": "string",
          "description": "Team UUID"
        },
        "name": {
          "type": "string",
          "description": "Team name"
        },
        "key": {
          "type": "string",
          "description": "Team key/identifier (used in issue IDs like 'HEX-57')"
        }
      }
    },
    "WorkflowState": {
      "type": "object",
      "description": "A workflow state (e.g., Todo, In Progress, Done)",
      "properties": {
        "id": {
          "type": "string",
          "description": "State UUID"
        },
        "name": {
          "type": "string",
          "description": "State name (e.g., 'Todo', 'In Progress', 'Done')"
        },
        "type": {
          "type": "string",
          "enum": ["triage", "backlog", "unstarted", "started", "completed", "canceled"],
          "description": "State type category"
        }
      }
    },
    "User": {
      "type": "object",
      "description": "A Linear user",
      "properties": {
        "id": {
          "type": "string",
          "description": "User UUID"
        },
        "name": {
          "type": "string",
          "description": "User display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        }
      }
    },
    "CommentCreateInput": {
      "type": "object",
      "description": "Input for creating a comment on an issue",
      "required": ["issueID", "body"],
      "properties": {
        "issueID": {
          "type": "string",
          "description": "Issue UUID to comment on (required)"
        },
        "body": {
          "type": "string",
          "description": "Comment text in markdown (required)"
        }
      }
    }
  },
  "methods": {
    "Viewer": {
      "description": "Get authenticated user information",
      "parameters": [],
      "returns": "User",
      "permissions": ["read"],
      "errors": ["AuthenticationError"]
    },
    "Teams": {
      "description": "List all teams with pagination",
      "parameters": [
        {
          "name": "first",
          "type": "integer",
          "required": false,
          "description": "Number of teams to return (default: ~50, max: 250)"
        },
        {
          "name": "after",
          "type": "string",
          "required": false,
          "description": "Cursor for pagination (from PageInfo.endCursor)"
        }
      ],
      "returns": "TeamConnection",
      "permissions": ["read"]
    },
    "Issues": {
      "description": "List issues with cursor-based pagination",
      "parameters": [
        {
          "name": "first",
          "type": "integer",
          "required": false,
          "description": "Number of issues to return (default: ~50, max: 250)"
        },
        {
          "name": "after",
          "type": "string",
          "required": false,
          "description": "Cursor for next page (from PageInfo.endCursor, nil = start)"
        }
      ],
      "returns": "IssueConnection",
      "permissions": ["read"],
      "example": "first := int64(10); issues, err := client.Issues(ctx, &first, nil)"
    },
    "Issue": {
      "description": "Get a single issue by ID",
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "Issue UUID"
        }
      ],
      "returns": "Issue",
      "permissions": ["read"]
    },
    "IssueCreate": {
      "description": "Create a new issue",
      "parameters": [
        {
          "name": "input",
          "type": "IssueCreateInput",
          "required": true,
          "description": "Issue creation parameters"
        }
      ],
      "returns": "Issue",
      "permissions": ["write"],
      "errors": ["AuthenticationError", "ForbiddenError", "RateLimitError"]
    },
    "IssueUpdate": {
      "description": "Update an existing issue",
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "Issue UUID to update"
        },
        {
          "name": "input",
          "type": "IssueUpdateInput",
          "required": true,
          "description": "Fields to update (nil = unchanged)"
        }
      ],
      "returns": "Issue",
      "permissions": ["write"]
    },
    "IssueDelete": {
      "description": "Delete an issue",
      "parameters": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "Issue UUID to delete"
        }
      ],
      "returns": "ArchivePayload",
      "permissions": ["write"]
    },
    "CommentCreate": {
      "description": "Create a comment on an issue",
      "parameters": [
        {
          "name": "input",
          "type": "CommentCreateInput",
          "required": true,
          "description": "Comment creation parameters"
        }
      ],
      "returns": "Comment",
      "permissions": ["write"]
    }
  }
}
